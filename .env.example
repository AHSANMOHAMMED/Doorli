# Database (must match docker-compose)
DATABASE_URL=postgresql://doorli_user:doorli_password@localhost:5432/doorli_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# API
API_PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET=doorli-dev-access-secret-change-in-prod
JWT_REFRESH_SECRET=doorli-dev-refresh-secret-change-in-prod
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
OTP_TTL_SECONDS=300

# Google Maps (Week 7+)
GOOGLE_MAPS_API_KEY=

# Payments (Week 13+)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=lkr
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_RETURN_URL=doorli://payment/success
PAYHERE_CANCEL_URL=doorli://payment/cancel
PAYHERE_NOTIFY_URL=http://localhost:4000/api/v1/payments/webhook/payhere

# Firebase Push (Week 15+)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVER_KEY=
FCM_SERVER_KEY=

# AI (optional)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
AI_PORT=4006
AI_SERVICE_URL=http://localhost:4006
SEARCH_SERVICE_URL=http://localhost:4004

# SMS OTP (Week 3+)
MSG91_API_KEY=

# File Storage (Week 5+)
AWS_S3_BUCKET=doorli-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_API_URL=http://localhost:4000
