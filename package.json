{
  "name": "doorli",
  "version": "0.1.0",
  "private": true,
  "description": "Doorli — Everything Local. Delivered.",
  "author": {
    "name": "AHSAN MOHAMMED",
    "email": "ahsanmohammed828@gmail.com"
  },
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "npm run migrate --workspace=@doorli/db",
    "db:migrate:deploy": "npm run migrate:deploy --workspace=@doorli/db",
    "db:seed": "npm run seed --workspace=@doorli/db",
    "db:generate": "npm run generate --workspace=@doorli/db",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
