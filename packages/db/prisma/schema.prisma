generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum UserRole {
  customer
  vendor
  driver
  admin
}

enum RideStatus {
  searching
  assigned
  arrived
  in_transit
  completed
  cancelled
}

enum VendorCategory {
  grocery
  restaurant
  hotel
  hall
  service
  beauty
}

enum OrderStatus {
  pending
  confirmed
  preparing
  ready
  picked_up
  delivered
  cancelled
}

enum OrderType {
  delivery
  pickup
  pos
}

enum PaymentMethod {
  card
  wallet
  cod
  cash
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum BookingType {
  hotel
  hall
  beauty
  service
}

enum BookingStatus {
  pending
  confirmed
  completed
  cancelled
}

enum ServiceRequestStatus {
  open
  assigned
  in_progress
  completed
  cancelled
}

enum VehicleType {
  bike
  car
  van
  truck
}

enum PaymentReferenceType {
  order
  booking
}

model LoyaltyPoint {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  points    Int      @default(0)
  earned    Int      @default(0)
  redeemed  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("loyalty_points")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  fullName        String   @map("full_name") @db.VarChar(100)
  username        String?  @unique @db.VarChar(50)
  phone           String?  @unique @db.VarChar(20)
  email           String?  @unique @db.VarChar(150)
  passwordHash    String?  @map("password_hash")
  role            UserRole @default(customer)
  profilePhotoUrl String?  @map("profile_photo_url")
  isVerified      Boolean  @default(false) @map("is_verified")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  addresses           Address[]
  vendor              Vendor?
  driver              Driver?
  loyaltyPoints       LoyaltyPoint?
  ordersAsCustomer    Order[]          @relation("CustomerOrders")
  ordersAsDriver      Order[]          @relation("DriverOrders")
  bookings            Booking[]
  serviceRequests     ServiceRequest[] @relation("CustomerServiceRequests")
  assignedServiceJobs ServiceRequest[] @relation("ProviderServiceRequests")
  reviews             Review[]
  payments            Payment[]
  notifications       Notification[]
  ridesAsCustomer     RideRequest[]    @relation("CustomerRides")
  deviceTokens        DeviceToken[]

  // Forum Domain Relations
  threads            Thread[]
  posts              Post[]
  moderatedForums    ForumModerator[]   @relation("UserAsModerator")
  grantedModerations ForumModerator[]   @relation("UserGrantedModerator")
  reputationRecords  ReputationRecord[]
  forumBans          ForumBan[]

  // Emergency Domain Relations
  reportedIncidents Incident[]  @relation("IncidentReporter")
  sentAlerts        Alert[]     @relation("AlertSender")
  sosRecords        SOSRecord[]
  dispatches        Dispatch[]  @relation("IncidentResponder")

  // GovTech Relations
  taxPayments TaxPayment[]
  licenses    License[]
  permits     Permit[]
  complaints  Complaint[]
  documents   DocumentVault[]

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model Address {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  label       String?  @db.VarChar(50)
  addressLine String   @map("address_line")
  city        String?  @db.VarChar(80)
  latitude    Decimal? @db.Decimal(10, 8)
  longitude   Decimal? @db.Decimal(11, 8)
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

model Vendor {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @unique @map("user_id") @db.Uuid
  businessName     String         @map("business_name") @db.VarChar(150)
  category         VendorCategory
  description      String?
  logoUrl          String?        @map("logo_url")
  bannerUrl        String?        @map("banner_url")
  phone            String?        @db.VarChar(20)
  addressLine      String?        @map("address_line")
  city             String?        @db.VarChar(80)
  latitude         Decimal?       @db.Decimal(10, 8)
  longitude        Decimal?       @db.Decimal(11, 8)
  openingHours     Json?          @map("opening_hours")
  isOpen           Boolean        @default(true) @map("is_open")
  isVerified       Boolean        @default(false) @map("is_verified")
  avgRating        Decimal        @default(0) @map("avg_rating") @db.Decimal(3, 2)
  totalReviews     Int            @default(0) @map("total_reviews")
  deliveryRadiusKm Int            @default(5) @map("delivery_radius_km")
  minOrderAmount   Decimal?       @map("min_order_amount") @db.Decimal(10, 2)
  erpTenantId      String?        @map("erp_tenant_id") @db.VarChar(50)
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  products          Product[]
  productAliases    ProductAlias[]
  orders            Order[]
  bookings          Booking[]
  reviews           Review[]
  supplierPurchases SupplierPurchase[]

  @@index([category])
  @@index([latitude, longitude])
  @@index([isOpen, isVerified])
  @@map("vendors")
}

model Product {
  id            String   @id @default(uuid()) @db.Uuid
  vendorId      String   @map("vendor_id") @db.Uuid
  name          String   @db.VarChar(200)
  description   String?
  category      String?  @db.VarChar(100)
  barcode       String?  @db.VarChar(64)
  sku           String?  @db.VarChar(64)
  price         Decimal  @db.Decimal(10, 2)
  discountPrice Decimal? @map("discount_price") @db.Decimal(10, 2)
  unit          String?  @db.VarChar(50)
  stockQuantity Int      @default(0) @map("stock_quantity")
  lowStockAt    Int      @default(5) @map("low_stock_at")
  imageUrl      String?  @map("image_url")
  isAvailable   Boolean  @default(true) @map("is_available")
  prepTimeMins  Int?     @map("prep_time_mins")
  addons        Json? // [{name, price}] for food customization
  allergens     Json? // string[]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  vendor     Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  aliases    ProductAlias[]

  @@unique([vendorId, barcode])
  @@index([vendorId])
  @@index([isAvailable])
  @@index([category])
  @@index([barcode])
  @@map("products")
}

/**
 * Vendor-local / supplier / slang names that map to a catalog product
 */
model ProductAlias {
  id        String   @id @default(uuid()) @db.Uuid
  vendorId  String   @map("vendor_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  alias     String   @db.VarChar(200)
  /**
   * Normalized form used for exact matching
   */
  aliasKey  String   @map("alias_key") @db.VarChar(220)
  createdAt DateTime @default(now()) @map("created_at")

  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([vendorId, aliasKey])
  @@index([vendorId])
  @@index([productId])
  @@map("product_aliases")
}

enum SupplierPurchaseStatus {
  draft
  confirmed
  cancelled
}

/**
 * Supplier invoice import → stock purchase batch
 */
model SupplierPurchase {
  id             String                 @id @default(uuid()) @db.Uuid
  vendorId       String                 @map("vendor_id") @db.Uuid
  supplierName   String?                @map("supplier_name") @db.VarChar(200)
  invoiceNumber  String?                @map("invoice_number") @db.VarChar(100)
  invoiceDate    DateTime?              @map("invoice_date")
  sourceFilename String?                @map("source_filename") @db.VarChar(255)
  sourceType     String                 @map("source_type") @db.VarChar(20) // csv | xlsx | pdf | text
  status         SupplierPurchaseStatus @default(draft)
  totalAmount    Decimal?               @map("total_amount") @db.Decimal(12, 2)
  rawExtract     Json?                  @map("raw_extract")
  notes          String?
  confirmedAt    DateTime?              @map("confirmed_at")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  vendor Vendor                 @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items  SupplierPurchaseItem[]

  @@index([vendorId, status])
  @@index([createdAt])
  @@map("supplier_purchases")
}

model SupplierPurchaseItem {
  id              String   @id @default(uuid()) @db.Uuid
  purchaseId      String   @map("purchase_id") @db.Uuid
  lineNo          Int      @map("line_no")
  invoiceName     String   @map("invoice_name") @db.VarChar(300)
  barcode         String?  @db.VarChar(64)
  sku             String?  @db.VarChar(64)
  quantity        Decimal  @db.Decimal(12, 3)
  unit            String?  @db.VarChar(40)
  unitCost        Decimal? @map("unit_cost") @db.Decimal(12, 4)
  lineTotal       Decimal? @map("line_total") @db.Decimal(12, 2)
  /**
   * matched | create_new | skip | needs_review
   */
  action          String   @default("needs_review") @db.VarChar(20)
  productId       String?  @map("product_id") @db.Uuid
  matchConfidence Int      @default(0) @map("match_confidence")
  matchMethod     String?  @map("match_method") @db.VarChar(40)
  /**
   * Save invoiceName as ProductAlias on confirm when true
   */
  saveAsAlias     Boolean  @default(true) @map("save_as_alias")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  purchase SupplierPurchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@map("supplier_purchase_items")
}

model Order {
  id                    String        @id @default(uuid()) @db.Uuid
  orderNumber           String        @unique @map("order_number") @db.VarChar(20)
  customerId            String        @map("customer_id") @db.Uuid
  vendorId              String        @map("vendor_id") @db.Uuid
  driverId              String?       @map("driver_id") @db.Uuid
  deliveryAddressId     String?       @map("delivery_address_id") @db.Uuid
  status                OrderStatus   @default(pending)
  orderType             OrderType     @default(delivery) @map("order_type")
  subtotal              Decimal       @db.Decimal(10, 2)
  deliveryFee           Decimal       @default(0) @map("delivery_fee") @db.Decimal(10, 2)
  discountAmount        Decimal       @default(0) @map("discount_amount") @db.Decimal(10, 2)
  totalAmount           Decimal       @map("total_amount") @db.Decimal(10, 2)
  paymentMethod         PaymentMethod @default(cod) @map("payment_method")
  paymentStatus         PaymentStatus @default(pending) @map("payment_status")
  estimatedDeliveryTime Int?          @map("estimated_delivery_time")
  specialInstructions   String?       @map("special_instructions")
  erpOrderId            String?       @map("erp_order_id") @db.VarChar(50)
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  customer        User        @relation("CustomerOrders", fields: [customerId], references: [id])
  vendor          Vendor      @relation(fields: [vendorId], references: [id])
  driver          User?       @relation("DriverOrders", fields: [driverId], references: [id])
  deliveryAddress Address?    @relation(fields: [deliveryAddressId], references: [id])
  items           OrderItem[]
  reviews         Review[]

  @@index([customerId])
  @@index([vendorId])
  @@index([driverId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  orderId    String  @map("order_id") @db.Uuid
  productId  String  @map("product_id") @db.Uuid
  quantity   Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(10, 2)
  notes      String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Booking {
  id            String        @id @default(uuid()) @db.Uuid
  bookingNumber String        @unique @map("booking_number") @db.VarChar(20)
  customerId    String        @map("customer_id") @db.Uuid
  vendorId      String        @map("vendor_id") @db.Uuid
  bookingType   BookingType   @map("booking_type")
  checkInDate   DateTime?     @map("check_in_date") @db.Date
  checkOutDate  DateTime?     @map("check_out_date") @db.Date
  eventDate     DateTime?     @map("event_date") @db.Date
  startTime     DateTime?     @map("start_time") @db.Time
  endTime       DateTime?     @map("end_time") @db.Time
  guestCount    Int?          @map("guest_count")
  totalAmount   Decimal       @map("total_amount") @db.Decimal(10, 2)
  depositAmount Decimal?      @map("deposit_amount") @db.Decimal(10, 2)
  status        BookingStatus @default(pending)
  requirements  String?
  durationMins  Int?          @map("duration_mins")
  roomType      String?       @map("room_type") @db.VarChar(100)
  amenities     Json?
  contractUrl   String?       @map("contract_url")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  customer User   @relation(fields: [customerId], references: [id])
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  @@index([customerId])
  @@index([vendorId])
  @@index([status])
  @@map("bookings")
}

model ServiceRequest {
  id                 String               @id @default(uuid()) @db.Uuid
  customerId         String               @map("customer_id") @db.Uuid
  assignedProviderId String?              @map("assigned_provider_id") @db.Uuid
  serviceType        String               @map("service_type") @db.VarChar(100)
  title              String               @db.VarChar(200)
  description        String?
  addressLine        String?              @map("address_line")
  latitude           Decimal?             @db.Decimal(10, 8)
  longitude          Decimal?             @db.Decimal(11, 8)
  isUrgent           Boolean              @default(false) @map("is_urgent")
  offeredRate        Decimal?             @map("offered_rate") @db.Decimal(10, 2)
  status             ServiceRequestStatus @default(open)
  scheduledAt        DateTime?            @map("scheduled_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  customer         User  @relation("CustomerServiceRequests", fields: [customerId], references: [id])
  assignedProvider User? @relation("ProviderServiceRequests", fields: [assignedProviderId], references: [id])

  @@index([customerId])
  @@index([assignedProviderId])
  @@index([status])
  @@index([serviceType])
  @@map("service_requests")
}

model Driver {
  id                 String                                 @id @default(uuid()) @db.Uuid
  userId             String                                 @unique @map("user_id") @db.Uuid
  vehicleType        VehicleType                            @map("vehicle_type")
  vehicleNumber      String?                                @map("vehicle_number") @db.VarChar(20)
  licenseNumber      String?                                @map("license_number") @db.VarChar(50)
  isOnline           Boolean                                @default(false) @map("is_online")
  location           Unsupported("GEOGRAPHY(POINT, 4326)")?
  currentLatitude    Decimal?                               @map("current_latitude") @db.Decimal(10, 8)
  currentLongitude   Decimal?                               @map("current_longitude") @db.Decimal(11, 8)
  lastLocationUpdate DateTime?                              @map("last_location_update")
  totalDeliveries    Int                                    @default(0) @map("total_deliveries")
  avgRating          Decimal                                @default(0) @map("avg_rating") @db.Decimal(3, 2)
  earningsToday      Decimal                                @default(0) @map("earnings_today") @db.Decimal(10, 2)
  createdAt          DateTime                               @default(now()) @map("created_at")
  updatedAt          DateTime                               @updatedAt @map("updated_at")

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  rides RideRequest[] @relation("DriverRides")

  @@index([isOnline])
  @@index([currentLatitude, currentLongitude])
  @@map("drivers")
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  reviewerId String   @map("reviewer_id") @db.Uuid
  vendorId   String   @map("vendor_id") @db.Uuid
  orderId    String?  @map("order_id") @db.Uuid
  rating     Int
  comment    String?
  photos     Json?
  createdAt  DateTime @default(now()) @map("created_at")

  reviewer User   @relation(fields: [reviewerId], references: [id])
  vendor   Vendor @relation(fields: [vendorId], references: [id])
  order    Order? @relation(fields: [orderId], references: [id])

  @@index([vendorId])
  @@index([reviewerId])
  @@map("reviews")
}

model Payment {
  id                   String               @id @default(uuid()) @db.Uuid
  referenceId          String               @map("reference_id") @db.Uuid
  referenceType        PaymentReferenceType @map("reference_type")
  userId               String               @map("user_id") @db.Uuid
  amount               Decimal              @db.Decimal(10, 2)
  currency             String               @default("LKR") @db.VarChar(10)
  method               PaymentMethod
  gateway              String?              @db.VarChar(50)
  gatewayTransactionId String?              @map("gateway_transaction_id")
  status               PaymentStatus        @default(pending)
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([referenceId, referenceType])
  @@index([userId])
  @@index([status])
  @@map("payments")
}

model Notification {
  id     String   @id @default(uuid()) @db.Uuid
  userId String   @map("user_id") @db.Uuid
  title  String   @db.VarChar(200)
  body   String
  type   String   @db.VarChar(80)
  data   Json?
  isRead Boolean  @default(false) @map("is_read")
  sentAt DateTime @default(now()) @map("sent_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model RideRequest {
  id            String     @id @default(uuid()) @db.Uuid
  customerId    String     @map("customer_id") @db.Uuid
  driverId      String?    @map("driver_id") @db.Uuid
  pickupLat     Decimal    @db.Decimal(10, 8)
  pickupLng     Decimal    @db.Decimal(11, 8)
  dropoffLat    Decimal    @db.Decimal(10, 8)
  dropoffLng    Decimal    @db.Decimal(11, 8)
  status        RideStatus @default(searching)
  baseFare      Decimal    @map("base_fare") @db.Decimal(10, 2)
  returnPremium Decimal    @default(0) @map("return_premium") @db.Decimal(10, 2)
  totalFare     Decimal    @map("total_fare") @db.Decimal(10, 2)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  customer User    @relation("CustomerRides", fields: [customerId], references: [id])
  driver   Driver? @relation("DriverRides", fields: [driverId], references: [id])

  @@index([customerId])
  @@index([driverId])
  @@index([status])
  @@map("ride_requests")
}

model GeographicZone {
  id          String                                   @id @default(uuid()) @db.Uuid
  name        String                                   @db.VarChar(100)
  city        String?                                  @db.VarChar(80)
  demandLevel Int                                      @default(1) @map("demand_level")
  boundaries  Unsupported("GEOGRAPHY(POLYGON, 4326)")?
  isActive    Boolean                                  @default(true) @map("is_active")
  createdAt   DateTime                                 @default(now()) @map("created_at")
  updatedAt   DateTime                                 @updatedAt @map("updated_at")

  @@map("geographic_zones")
}

model PromoCode {
  id             String    @id @default(uuid()) @db.Uuid
  code           String    @unique @db.VarChar(40)
  description    String?
  discountType   String    @map("discount_type") @db.VarChar(20) // percent | fixed
  discountValue  Decimal   @map("discount_value") @db.Decimal(10, 2)
  minOrderAmount Decimal?  @map("min_order_amount") @db.Decimal(10, 2)
  maxUses        Int?      @map("max_uses")
  usedCount      Int       @default(0) @map("used_count")
  vendorId       String?   @map("vendor_id") @db.Uuid
  isActive       Boolean   @default(true) @map("is_active")
  startsAt       DateTime? @map("starts_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("promo_codes")
}

model FlashSale {
  id          String   @id @default(uuid()) @db.Uuid
  vendorId    String   @map("vendor_id") @db.Uuid
  productId   String?  @map("product_id") @db.Uuid
  title       String   @db.VarChar(150)
  discountPct Int      @map("discount_pct")
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([vendorId, isActive])
  @@map("flash_sales")
}

model EventPackage {
  id            String   @id @default(uuid()) @db.Uuid
  customerId    String   @map("customer_id") @db.Uuid
  title         String   @db.VarChar(200)
  eventDate     DateTime @map("event_date") @db.Date
  guestCount    Int?     @map("guest_count")
  venueVendorId String?  @map("venue_vendor_id") @db.Uuid
  status        String   @default("draft") @db.VarChar(40)
  totalEstimate Decimal? @map("total_estimate") @db.Decimal(12, 2)
  items         Json     @default("[]")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@map("event_packages")
}

model DeliverySubscription {
  id              String   @id @default(uuid()) @db.Uuid
  customerId      String   @map("customer_id") @db.Uuid
  vendorId        String   @map("vendor_id") @db.Uuid
  frequency       String   @db.VarChar(20) // weekly | biweekly | monthly
  nextDeliveryAt  DateTime @map("next_delivery_at")
  items           Json
  deliveryAddress String   @map("delivery_address")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([customerId, isActive])
  @@index([nextDeliveryAt])
  @@map("delivery_subscriptions")
}

model DeviceToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.VarChar(512)
  platform  String   @db.VarChar(20) // ios | android | web
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

// ==========================================
// Community Forums Domain
// ==========================================

model Forum {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(100)
  description String?
  category    String   @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  threads    Thread[]
  moderators ForumModerator[]

  @@map("forums")
}

model Thread {
  id        String   @id @default(uuid()) @db.Uuid
  forumId   String   @map("forum_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  title     String   @db.VarChar(200)
  content   String
  isPinned  Boolean  @default(false) @map("is_pinned")
  isLocked  Boolean  @default(false) @map("is_locked")
  viewCount Int      @default(0) @map("view_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  forum  Forum  @relation(fields: [forumId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])
  posts  Post[]

  @@index([forumId])
  @@index([authorId])
  @@map("threads")
}

model Post {
  id        String   @id @default(uuid()) @db.Uuid
  threadId  String   @map("thread_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  content   String
  isDeleted Boolean  @default(false) @map("is_deleted")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  thread  Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author  User   @relation(fields: [authorId], references: [id])
  parent  Post?  @relation("PostReplies", fields: [parentId], references: [id])
  replies Post[] @relation("PostReplies")

  @@index([threadId])
  @@index([authorId])
  @@index([parentId])
  @@map("posts")
}

model ForumModerator {
  id        String   @id @default(uuid()) @db.Uuid
  forumId   String   @map("forum_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  grantedBy String   @map("granted_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  forum   Forum @relation(fields: [forumId], references: [id], onDelete: Cascade)
  user    User  @relation("UserAsModerator", fields: [userId], references: [id])
  granter User  @relation("UserGrantedModerator", fields: [grantedBy], references: [id])

  @@unique([forumId, userId])
  @@map("forum_moderators")
}

model ReputationRecord {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  points    Int
  reason    String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("reputation_records")
}

model ForumBan {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  forumId   String?   @map("forum_id") @db.Uuid // null = global ban
  reason    String    @db.VarChar(200)
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("forum_bans")
}

// ==========================================
// Emergency Response Domain
// ==========================================

model Incident {
  id          String                                 @id @default(uuid()) @db.Uuid
  reporterId  String                                 @map("reporter_id") @db.Uuid
  type        String                                 @db.VarChar(50) // fire, medical, police, etc.
  description String?
  latitude    Decimal                                @db.Decimal(10, 8)
  longitude   Decimal                                @db.Decimal(11, 8)
  location    Unsupported("GEOGRAPHY(POINT, 4326)")?
  status      ServiceRequestStatus                   @default(open)
  mediaUrls   Json?                                  @map("media_urls")
  isAnonymous Boolean                                @default(false) @map("is_anonymous")
  createdAt   DateTime                               @default(now()) @map("created_at")
  updatedAt   DateTime                               @updatedAt @map("updated_at")

  reporter   User       @relation("IncidentReporter", fields: [reporterId], references: [id])
  dispatches Dispatch[]

  @@index([reporterId])
  @@index([status])
  @@map("incidents")
}

model Alert {
  id        String                                   @id @default(uuid()) @db.Uuid
  senderId  String                                   @map("sender_id") @db.Uuid
  type      String                                   @db.VarChar(50)
  priority  String                                   @db.VarChar(20) // info, warning, critical
  message   String
  geofence  Unsupported("GEOGRAPHY(POLYGON, 4326)")?
  status    String                                   @default("active") @db.VarChar(20)
  createdAt DateTime                                 @default(now()) @map("created_at")
  expiresAt DateTime?                                @map("expires_at")

  sender User @relation("AlertSender", fields: [senderId], references: [id])

  @@index([senderId])
  @@map("emergency_alerts")
}

model SOSRecord {
  id           String                                 @id @default(uuid()) @db.Uuid
  userId       String                                 @map("user_id") @db.Uuid
  latitude     Decimal                                @db.Decimal(10, 8)
  longitude    Decimal                                @db.Decimal(11, 8)
  location     Unsupported("GEOGRAPHY(POINT, 4326)")?
  status       String                                 @default("active") @db.VarChar(20)
  recordingUrl String?                                @map("recording_url")
  createdAt    DateTime                               @default(now()) @map("created_at")
  resolvedAt   DateTime?                              @map("resolved_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sos_records")
}

model Dispatch {
  id           String    @id @default(uuid()) @db.Uuid
  incidentId   String    @map("incident_id") @db.Uuid
  responderId  String    @map("responder_id") @db.Uuid
  status       String    @default("assigned") @db.VarChar(20)
  dispatchedAt DateTime  @default(now()) @map("dispatched_at")
  arrivedAt    DateTime? @map("arrived_at")
  completedAt  DateTime? @map("completed_at")

  incident  Incident @relation(fields: [incidentId], references: [id])
  responder User     @relation("IncidentResponder", fields: [responderId], references: [id])

  @@index([incidentId])
  @@index([responderId])
  @@map("dispatches")
}

// -----------------------------------------
// GovTech Domain
// -----------------------------------------

model GovernmentService {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String
  category    String // e.g., "tax", "permit", "license"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permits     Permit[]
  licenses    License[]
  taxPayments TaxPayment[]
  complaints  Complaint[]

  @@map("government_services")
}

model TaxPayment {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  serviceId String   @map("service_id") @db.Uuid
  amount    Decimal  @db.Decimal(10, 2)
  status    String   @default("pending") @db.VarChar(20) // pending, completed, failed
  taxPeriod String   @map("tax_period") @db.VarChar(50) // e.g., "2023-Q1"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    User              @relation(fields: [userId], references: [id])
  service GovernmentService @relation(fields: [serviceId], references: [id])

  @@index([userId])
  @@map("tax_payments")
}

model License {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  serviceId String    @map("service_id") @db.Uuid
  licenseNo String    @unique @map("license_no") @db.VarChar(100)
  status    String    @default("active") @db.VarChar(20) // active, expired, suspended
  issuedAt  DateTime  @default(now()) @map("issued_at")
  expiresAt DateTime? @map("expires_at")

  user    User              @relation(fields: [userId], references: [id])
  service GovernmentService @relation(fields: [serviceId], references: [id])

  @@index([userId])
  @@map("licenses")
}

model Permit {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  serviceId String    @map("service_id") @db.Uuid
  permitNo  String    @unique @map("permit_no") @db.VarChar(100)
  status    String    @default("pending") @db.VarChar(20) // pending, approved, rejected
  issuedAt  DateTime? @map("issued_at")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user    User              @relation(fields: [userId], references: [id])
  service GovernmentService @relation(fields: [serviceId], references: [id])

  @@index([userId])
  @@map("permits")
}

model Complaint {
  id          String                                 @id @default(uuid()) @db.Uuid
  userId      String                                 @map("user_id") @db.Uuid
  serviceId   String?                                @map("service_id") @db.Uuid
  title       String
  description String
  status      String                                 @default("open") @db.VarChar(20) // open, in_progress, resolved, closed
  category    String                                 @db.VarChar(50) // e.g., "infrastructure", "sanitation"
  location    Unsupported("GEOGRAPHY(POINT, 4326)")?
  createdAt   DateTime                               @default(now()) @map("created_at")
  updatedAt   DateTime                               @updatedAt @map("updated_at")

  user    User               @relation(fields: [userId], references: [id])
  service GovernmentService? @relation(fields: [serviceId], references: [id])

  @@index([userId])
  @@map("complaints")
}

model DocumentVault {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  documentName String   @map("document_name")
  documentType String   @map("document_type") // e.g., "id_card", "tax_return", "proof_of_address"
  fileUrl      String   @map("file_url") // S3/GCS URL
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("document_vaults")
}

model PublicConsultation {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String
  status      String   @default("open") @db.VarChar(20) // open, closed
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("public_consultations")
}
